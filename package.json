{
  "name": "shipspark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "node scripts/build-css.mjs",
    "dev": "npm run build:css && wrangler dev --persist-to .wrangler/state",
    "deploy": "npm run build:css && wrangler deploy",
    "typecheck": "npm run build:css && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply shipspark --local",
    "db:migrate:prod": "wrangler d1 migrations apply shipspark --remote"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.10.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260220.0",
    "@tailwindcss/cli": "^4.2.0",
    "drizzle-kit": "^0.31.6",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.2",
    "wrangler": "^4.43.0"
  }
}
